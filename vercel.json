{
    "rootDirectory": "artifacts/portfolio",
    "buildCommand": "pnpm run build",
    "outputDirectory": "dist/public",
    "installCommand": "corepack enable && pnpm install",
    "framework": "vite",
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}
